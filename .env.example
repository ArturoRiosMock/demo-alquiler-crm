# Supabase (requerido para auth / BD)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Geoapify: mapas en Excel (cliente) y geocodificación + mapa tras enriquecimiento Catastro (servidor)
# Misma clave suele valer para ambas; el servidor usa GEOAPIFY_API_KEY o NEXT_PUBLIC_GEOAPIFY_KEY.
NEXT_PUBLIC_GEOAPIFY_KEY=
GEOAPIFY_API_KEY=

# Opcional: tras enrichAssetsWithCatastro, persistir activos en Supabase (requiere sesión válida)
ASSET_UPSERT_AFTER_CATASTRO_ENRICH=false
